APP_NAME="Pretoria Precision Rifle Club"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://pretoriaprc.co.za

APP_TIMEZONE=Africa/Johannesburg
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_ZA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# -------- Database (PostgreSQL) --------
DB_CONNECTION=pgsql
DB_HOST=pprc-pgsql
DB_PORT=5432
DB_DATABASE=pprc
DB_USERNAME=pprc
DB_PASSWORD=change-me-strong-random-password

# -------- Cache / session / queue / redis --------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=database

REDIS_CLIENT=phpredis
REDIS_HOST=pprc-redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# -------- Filesystem (Cloudflare R2, S3-compatible) --------
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=change-me-r2-access-key-id
AWS_SECRET_ACCESS_KEY=change-me-r2-secret-access-key
AWS_DEFAULT_REGION=auto
AWS_BUCKET=pprc-media
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_URL=https://media.pretoriaprc.co.za

# -------- Mail (Mailgun) --------
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS=no-reply@pretoriaprc.co.za
MAIL_FROM_NAME="${APP_NAME}"
MAILGUN_DOMAIN=mg.pretoriaprc.co.za
MAILGUN_SECRET=change-me-mailgun-api-key
MAILGUN_ENDPOINT=api.eu.mailgun.net

# -------- Paystack --------
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# -------- Trust proxy (Nginx Proxy Manager) --------
TRUSTED_PROXIES=*

# -------- App boot --------
APP_RUN_MIGRATIONS_ON_BOOT=true

VITE_APP_NAME="${APP_NAME}"
